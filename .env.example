# ============================================================================
# Tirapro — biến môi trường (single source of truth). Copy sang .env để chạy.
# Mọi biến mới PHẢI được thêm vào file này.
# ============================================================================

# ---------- Node ----------
NODE_ENV=development

# ---------- PostgreSQL (image: pgvector/pgvector:pg16) ----------
POSTGRES_USER=projira
POSTGRES_PASSWORD=projira
POSTGRES_DB=projira
POSTGRES_PORT=5432
DATABASE_URL="postgresql://projira:projira@localhost:5432/projira?schema=public&connection_limit=10&pool_timeout=20"
# DIRECT_URL: kết nối trực tiếp (bypass PgBouncer) cho prisma migrate. Dev = trùng DATABASE_URL.
DIRECT_URL="postgresql://projira:projira@localhost:5432/projira?schema=public"

# ---------- Redis (socket.io adapter + BullMQ + cache + presence + throttle) ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL="redis://localhost:6379"

# ---------- Adminer ----------
ADMINER_PORT=8080

# ---------- API (NestJS) ----------
API_PORT=4000
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=api
API_VERSION=v1
CORS_ORIGIN=http://localhost:5173

# ---------- Auth (JWT access + refresh rotation) ----------
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_32_chars_long_0001
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_32_chars_long_002
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ---------- Realtime (Socket.io) ----------
WS_PATH=/realtime
WS_USE_REDIS_ADAPTER=true

# ---------- Storage (Attachments) ----------
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
MAX_FILE_SIZE_MB=25
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

# ---------- AI: Anthropic Claude (thiếu key -> degrade gracefully) ----------
ANTHROPIC_API_KEY=
AI_FEATURES_ENABLED=true
AI_MODEL_PRIMARY=claude-opus-4-8
AI_MODEL_FAST=claude-sonnet-4-6
AI_MONTHLY_TOKEN_QUOTA_PER_WORKSPACE=5000000

# ---------- AI: Embeddings (Anthropic KHÔNG có embedding API) ----------
EMBEDDING_PROVIDER=none
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
OPENAI_API_KEY=
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# ---------- Rate limiting (@nestjs/throttler qua Redis) ----------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---------- Integrations ----------
# Bot Telegram toàn cục (optional). Để trống nếu mỗi workspace tự dùng bot riêng (BYO).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_DOMAIN=
# Khóa mã hóa secret tích hợp (AES-256-GCM), tối thiểu 32 ký tự.
INTEGRATION_ENCRYPTION_KEY=dev_integration_encryption_key_change_me_0001

# ---------- Web (Vite — chỉ biến VITE_* lộ ra client, KHÔNG đặt secret) ----------
VITE_API_URL=http://localhost:4000/api/v1
VITE_WS_URL=http://localhost:4000
VITE_APP_NAME=Tirapro
VITE_ENABLE_PWA=true
