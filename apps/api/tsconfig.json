{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "incremental": false,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "types": ["node", "multer"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}
